---
import Base from '../layouts/Base.astro';
---

<Base title="Aryan D Haritsa — AI/ML Researcher & Engineer">

  <!-- ==================================================
       HERO — Kinetic editorial split
       ================================================== -->
  <section class="relative min-h-[92vh] flex items-center overflow-hidden">

    <!-- Faint grid beneath hero -->
    <div class="absolute inset-0 bg-grid bg-grid-fade opacity-50 pointer-events-none"></div>

    <!-- Giant outlined number — Ramanujan's 1729 -->
    <div class="absolute right-[-4vw] top-[6vh] pointer-events-none select-none hidden md:block" aria-hidden="true">
      <svg viewBox="0 0 500 300" class="w-[60vw] max-w-[900px] h-auto opacity-[0.065]">
        <text x="0" y="230" style="font-family: var(--font-serif); font-size: 300px; font-weight: 300; letter-spacing: -0.05em;"
              fill="none" stroke="#0F2A4A" stroke-width="1.5">1729</text>
      </svg>
    </div>

    <div class="container-wide relative py-20 md:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

        <!-- Left — the display -->
        <div class="lg:col-span-8">
          <p class="reveal section-label mb-6">
            <span class="inline-flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
              AI/ML Researcher & Engineer · Bengaluru
            </span>
          </p>

          <h1 class="mb-7" style="font-family: var(--font-serif); color: var(--color-accent);">
            <span class="block text-[11vw] md:text-[9vw] lg:text-[8.4rem] leading-[0.92] font-light tracking-[-0.035em]">
              <span class="split-word"><span class="split">Aryan</span></span>
            </span>
            <span class="block text-[11vw] md:text-[9vw] lg:text-[8.4rem] leading-[0.92] font-light tracking-[-0.035em]">
              <span class="split-word"><span class="split">Haritsa.</span></span>
            </span>
          </h1>

          <p class="reveal text-lg md:text-xl text-[var(--color-muted)] leading-relaxed max-w-[640px] mb-3">
            I work at the boundary between <em class="text-[var(--color-ink)] not-italic font-medium">what models can do</em> and
            <em class="text-[var(--color-ink)] not-italic font-medium">what we can reliably deploy</em>.
          </p>
          <p class="reveal text-base md:text-lg text-[var(--color-muted)] leading-relaxed max-w-[640px] mb-10">
            Currently: mechanistic interpretability of in-context learning, a 6-encoder Pareto study of dense retrieval architectures, and the occasional 3-week-sprint Kaggle stack.
          </p>

          <div class="reveal flex flex-wrap gap-3 items-center">
            <a href="/projects/ramanujan" class="btn-primary magnetic">
              <span class="font-mono text-xs">36/50</span>
              Project Ramanujan
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="/projects/vitruvius" class="btn-ghost magnetic">
              Vitruvius Results
            </a>
            <a href="/research" class="btn-ghost magnetic">
              Research
            </a>
          </div>

          <div class="reveal mt-10 flex items-center gap-3 text-xs text-[var(--color-faint)]">
            <span class="kbd">1729</span>
            <span>press the digits anywhere for a taxicab surprise</span>
          </div>
        </div>

        <!-- Right — live status card -->
        <div class="lg:col-span-4 lg:pl-6">
          <div class="reveal-right card shimmer-border">
            <div class="accent-bar"></div>
            <div class="p-6">
              <div class="flex items-center justify-between mb-4">
                <p class="section-label">Now</p>
                <span class="text-xs font-mono text-[var(--color-faint)]">Apr 2026</span>
              </div>
              <ul class="space-y-4 text-sm">
                <li class="flex gap-3">
                  <span class="mt-1 w-2 h-2 rounded-full bg-emerald-500 flex-shrink-0 animate-pulse"></span>
                  <div>
                    <p class="font-semibold text-[var(--color-ink)]">Project Rick @ Kudelski</p>
                    <p class="text-[var(--color-muted)] text-xs leading-relaxed">Agentic chatbot orchestrating AWS Bedrock, Athena, Glue, Teams.</p>
                  </div>
                </li>
                <li class="flex gap-3">
                  <span class="mt-1 w-2 h-2 rounded-full bg-[var(--color-gold)] flex-shrink-0"></span>
                  <div>
                    <p class="font-semibold text-[var(--color-ink)]">Vitruvius @ 90%</p>
                    <p class="text-[var(--color-muted)] text-xs leading-relaxed">Position-sensitivity sweep landed. LSTM upset the hypothesis.</p>
                  </div>
                </li>
                <li class="flex gap-3">
                  <span class="mt-1 w-2 h-2 rounded-full bg-[var(--color-accent)] flex-shrink-0"></span>
                  <div>
                    <p class="font-semibold text-[var(--color-ink)]">Orpheus — mesa-optimization probe</p>
                    <p class="text-[var(--color-muted)] text-xs leading-relaxed">Training small transformers; TransformerLens harness live.</p>
                  </div>
                </li>
                <li class="flex gap-3">
                  <span class="mt-1 w-2 h-2 rounded-full bg-slate-400 flex-shrink-0"></span>
                  <div>
                    <p class="font-semibold text-[var(--color-ink)]">ARC AGI 3 · Kaggle</p>
                    <p class="text-[var(--color-muted)] text-xs leading-relaxed">Active submission loop.</p>
                  </div>
                </li>
              </ul>
              <div class="mt-6 pt-4 border-t border-[var(--color-rule)] flex items-center justify-between text-xs">
                <span class="text-[var(--color-faint)]">MSR India · UGR applied</span>
                <a href="/about" class="ink-link">Read more →</a>
              </div>
            </div>
          </div>

          <!-- Tiny stat grid -->
          <div class="grid grid-cols-2 gap-3 mt-5 reveal-right">
            <div class="stat-block">
              <span class="stat-number counter"><span data-count="36">0</span>/50</span>
              <span class="stat-label">AIMO Prize 3</span>
            </div>
            <div class="stat-block">
              <span class="stat-number">22,878</span>
              <span class="stat-label">Per-query shuffle rows</span>
            </div>
            <div class="stat-block">
              <span class="stat-number">116.8<span class="text-base font-normal">B</span></span>
              <span class="stat-label">Params, MoE</span>
            </div>
            <div class="stat-block">
              <span class="stat-number">8.05</span>
              <span class="stat-label">CGPA · PES Univ.</span>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-[var(--color-faint)] text-[10px] tracking-[0.2em] uppercase reveal">
      <span>Scroll</span>
      <span class="w-px h-10 bg-gradient-to-b from-[var(--color-faint)] to-transparent"></span>
    </div>
  </section>

  <!-- ==================================================
       MARQUEE — research keywords
       ================================================== -->
  <section class="py-5 border-y border-[var(--color-rule)] bg-[var(--color-bg-deep)]/60 overflow-hidden">
    <div class="marquee">
      <div class="marquee__track">
        <span class="marquee__item">Mechanistic Interpretability<span class="dot"></span></span>
        <span class="marquee__item">State-Space Models<span class="dot"></span></span>
        <span class="marquee__item">Inference-time Reasoning<span class="dot"></span></span>
        <span class="marquee__item">Attention Head Pruning<span class="dot"></span></span>
        <span class="marquee__item">Dense Retrieval<span class="dot"></span></span>
        <span class="marquee__item">Mesa-Optimization<span class="dot"></span></span>
        <span class="marquee__item">Zero-Knowledge Proofs<span class="dot"></span></span>
        <span class="marquee__item">Tool-Integrated Reasoning<span class="dot"></span></span>
      </div>
      <div class="marquee__track" aria-hidden="true">
        <span class="marquee__item">Mechanistic Interpretability<span class="dot"></span></span>
        <span class="marquee__item">State-Space Models<span class="dot"></span></span>
        <span class="marquee__item">Inference-time Reasoning<span class="dot"></span></span>
        <span class="marquee__item">Attention Head Pruning<span class="dot"></span></span>
        <span class="marquee__item">Dense Retrieval<span class="dot"></span></span>
        <span class="marquee__item">Mesa-Optimization<span class="dot"></span></span>
        <span class="marquee__item">Zero-Knowledge Proofs<span class="dot"></span></span>
        <span class="marquee__item">Tool-Integrated Reasoning<span class="dot"></span></span>
      </div>
    </div>
  </section>

  <!-- ==================================================
       INTRO — About band (dark)
       ================================================== -->
  <section class="relative bg-[var(--color-dark)] text-white py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.08]" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="dots-hero" x="0" y="0" width="24" height="24" patternUnits="userSpaceOnUse">
            <circle cx="1" cy="1" r="0.6" fill="white"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#dots-hero)"/>
      </svg>
    </div>
    <div class="absolute top-0 right-0 w-[480px] h-[480px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(180,137,42,0.25), transparent 60%);"></div>

    <div class="container-wide relative">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
        <div class="md:col-span-4">
          <p class="text-[11px] uppercase tracking-[0.16em] text-[var(--color-gold)] font-semibold mb-4">01 · Framing</p>
          <h2 class="text-3xl md:text-4xl font-light leading-tight" style="font-family: var(--font-serif);">
            Engineering under<br/>constraint.<br/>
            <span class="text-[var(--color-gold)] italic">Curiosity beneath.</span>
          </h2>
        </div>
        <div class="md:col-span-8 md:pt-2">
          <p class="reveal text-lg md:text-xl leading-relaxed text-white/85">
            I build systems that have to actually run — a 116-billion-parameter MoE on two consumer GPUs, a 6-encoder retrieval Pareto on a real budget, a ZK-backed KYC pipeline with a cryptographic reason for being.
          </p>
          <p class="reveal text-base md:text-lg leading-relaxed text-white/60 mt-5 max-w-2xl">
            Underneath the shipping is a quieter question: <span class="text-white/90">what are these networks actually computing?</span> Most of my research time goes there — activation patching, head ablations, position shuffles, failure taxonomies. The job of the engineering is to earn the right to ask.
          </p>
          <div class="reveal mt-8 flex flex-wrap gap-3">
            <a href="/about" class="btn-ghost !border-white/25 !text-white hover:!bg-white/10">About →</a>
            <a href="/research" class="btn-ghost !border-white/25 !text-white hover:!bg-white/10">Research</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================================================
       RESEARCH THREADS — detailed two-up
       ================================================== -->
  <section class="py-24 relative">
    <div class="container-wide">
      <div class="reveal flex items-end justify-between mb-12 flex-wrap gap-4">
        <div>
          <p class="section-label mb-3">02 · Research threads</p>
          <h2 class="text-3xl md:text-5xl font-light" style="font-family: var(--font-serif); color: var(--color-accent);">
            Two questions I can't<br/>stop asking.
          </h2>
        </div>
        <a href="/research" class="ink-link text-sm">All research →</a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 stagger">

        <!-- ORPHEUS -->
        <a href="/projects/orpheus" class="reveal card shimmer-border group">
          <div class="h-[3px] bg-gradient-to-r from-[#0F2A4A] via-[#1E4E7A] to-[#4A90D9]"></div>
          <div class="p-7 md:p-9">
            <div class="flex items-center justify-between mb-4">
              <span class="pill pill-gold">Orpheus · Active</span>
              <span class="font-mono text-[11px] text-[var(--color-faint)]">probe / mesa-opt</span>
            </div>
            <h3 class="text-2xl md:text-3xl font-semibold mb-2 group-hover:text-[var(--color-gold-deep)] transition-colors" style="font-family: var(--font-serif);">
              Orpheus
            </h3>
            <p class="text-sm text-[var(--color-muted)] uppercase tracking-wider mb-5">Mesa-Optimization Probe</p>
            <p class="text-[var(--color-ink)] leading-relaxed mb-5">
              Do small transformers trained on in-context linear regression <em>implement gradient descent</em> internally — or merely retrieve from a lookup table? Reverse-engineering the circuits that decide.
            </p>
            <div class="flex flex-wrap gap-2 mb-5">
              <span class="pill pill-accent">TransformerLens</span>
              <span class="pill pill-accent">Activation patching</span>
              <span class="pill pill-accent">In-context learning</span>
            </div>
            <div class="flex items-center gap-2 text-sm font-medium text-[var(--color-accent)]">
              <span>Open the probe</span>
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </div>
          </div>
        </a>

        <!-- VITRUVIUS -->
        <a href="/projects/vitruvius" class="reveal card shimmer-border group">
          <div class="h-[3px] bg-gradient-to-r from-[#B4892A] via-[#1E4E7A] to-[#0F2A4A]"></div>
          <div class="p-7 md:p-9">
            <div class="flex items-center justify-between mb-4">
              <span class="pill pill-gold">Vitruvius · 90%</span>
              <span class="font-mono text-[11px] text-[var(--color-faint)]">v0.8.0 · phase 8</span>
            </div>
            <h3 class="text-2xl md:text-3xl font-semibold mb-2 group-hover:text-[var(--color-gold-deep)] transition-colors" style="font-family: var(--font-serif);">
              Vitruvius
            </h3>
            <p class="text-sm text-[var(--color-muted)] uppercase tracking-wider mb-5">Encoder Archaeology</p>
            <p class="text-[var(--color-ink)] leading-relaxed mb-4">
              A 6-encoder Pareto comparison for dense retrieval: transformer vs SSM vs recurrent vs convolutional. Latency. Pruning. Position shuffles. Measured, not argued.
            </p>
            <!-- Mini Pareto teaser -->
            <svg viewBox="0 0 320 110" class="w-full h-[110px] mb-4">
              <line x1="20" y1="90" x2="300" y2="90" stroke="#DED8CA" stroke-width="1"/>
              <line x1="20" y1="10" x2="20" y2="90" stroke="#DED8CA" stroke-width="1"/>
              <!-- Pareto dashed line -->
              <path d="M50 82 L80 78 L150 50 L220 38 L270 30" stroke="#B4892A" stroke-width="1" stroke-dasharray="2 3" fill="none"/>
              <!-- Points -->
              <circle cx="50" cy="84" r="3" fill="#8A6414"/>
              <circle cx="80" cy="78" r="3" fill="#8A6414"/>
              <circle cx="150" cy="50" r="4" fill="#0F2A4A"/>
              <circle cx="180" cy="60" r="3" fill="#0F2A4A"/>
              <circle cx="220" cy="38" r="4" fill="#0F2A4A"/>
              <circle cx="260" cy="70" r="3" fill="#B4892A"/>
              <text x="52" y="103" font-size="8" font-family="var(--font-mono)" fill="#8a8a85">conv</text>
              <text x="78" y="103" font-size="8" font-family="var(--font-mono)" fill="#8a8a85">lstm</text>
              <text x="142" y="103" font-size="8" font-family="var(--font-mono)" fill="#8a8a85">minilm</text>
              <text x="215" y="103" font-size="8" font-family="var(--font-mono)" fill="#8a8a85">gte</text>
              <text x="258" y="103" font-size="8" font-family="var(--font-mono)" fill="#8a8a85">mamba</text>
              <text x="4" y="14" font-size="7" font-family="var(--font-mono)" fill="#8a8a85">nDCG↑</text>
              <text x="244" y="22" font-size="8" font-family="var(--font-mono)" fill="#B4892A" font-style="italic">Pareto frontier</text>
            </svg>
            <div class="flex flex-wrap gap-2 mb-5">
              <span class="pill pill-accent">BEIR</span>
              <span class="pill pill-accent">Mamba</span>
              <span class="pill pill-accent">Head pruning</span>
              <span class="pill pill-accent">Position shuffle</span>
            </div>
            <div class="flex items-center gap-2 text-sm font-medium text-[var(--color-accent)]">
              <span>Full results & case study</span>
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ==================================================
       FEATURED CASE STUDY — Ramanujan
       ================================================== -->
  <section class="py-24 bg-[var(--color-bg-deep)]/50 relative overflow-hidden">
    <div class="absolute inset-0 bg-grid bg-grid-fade opacity-40 pointer-events-none"></div>
    <div class="container-wide relative">
      <div class="reveal mb-10">
        <p class="section-label mb-3">03 · Featured</p>
        <h2 class="text-3xl md:text-5xl font-light" style="font-family: var(--font-serif); color: var(--color-accent);">
          Three weeks, solo, <span class="italic">36/50</span>.
        </h2>
      </div>

      <a href="/projects/ramanujan" class="block reveal card shimmer-border overflow-hidden">
        <div class="accent-bar"></div>
        <div class="grid grid-cols-1 md:grid-cols-12">
          <div class="md:col-span-8 p-8 md:p-12">
            <p class="text-xs uppercase tracking-[0.12em] text-[var(--color-gold-deep)] font-semibold mb-3">AIMO Prize 3 · Kaggle · March 2026</p>
            <h3 class="text-3xl md:text-4xl font-semibold mb-4" style="font-family: var(--font-serif); color: var(--color-accent);">Project Ramanujan</h3>
            <p class="text-[var(--color-ink)] leading-relaxed mb-5 max-w-2xl">
              The competition had been running for five months. Most teams started in November. I entered in the second week of March with nothing but a model checkpoint and an idea. Three weeks later, I had the highest public score on the leaderboard — beating the previous year's winning solution.
            </p>
            <div class="flex flex-wrap gap-2 mb-6">
              <span class="pill pill-gold">GPT-OSS-120B</span>
              <span class="pill pill-accent">vLLM</span>
              <span class="pill pill-accent">Harmony</span>
              <span class="pill pill-accent">TIR · N=8</span>
              <span class="pill pill-accent">Entropy voting</span>
            </div>
            <span class="ink-link text-sm font-medium">Read the full build log →</span>
          </div>
          <div class="md:col-span-4 bg-[var(--color-dark)] text-white p-8 md:p-10 flex flex-col justify-between">
            <div>
              <p class="font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--color-gold)] mb-2">Score</p>
              <p class="text-7xl font-light" style="font-family: var(--font-serif);">36<span class="text-white/40">/50</span></p>
              <p class="text-[var(--color-gold)] text-sm mt-4">+2 over AIMO 2 winner</p>
            </div>
            <div class="mt-8 pt-5 border-t border-white/10 grid grid-cols-2 gap-4 text-xs text-white/70">
              <div>
                <p class="text-white/50 uppercase tracking-wider text-[10px]">Wall clock</p>
                <p class="mt-1 font-mono">5h / 50</p>
              </div>
              <div>
                <p class="text-white/50 uppercase tracking-wider text-[10px]">Samples</p>
                <p class="mt-1 font-mono">N = 8</p>
              </div>
              <div>
                <p class="text-white/50 uppercase tracking-wider text-[10px]">GPUs</p>
                <p class="mt-1 font-mono">Kaggle T4×2</p>
              </div>
              <div>
                <p class="text-white/50 uppercase tracking-wider text-[10px]">Active params</p>
                <p class="mt-1 font-mono">5.1 B (MoE)</p>
              </div>
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ==================================================
       PROJECT GRID — asymmetric
       ================================================== -->
  <section class="py-24">
    <div class="container-wide">
      <div class="reveal flex items-end justify-between flex-wrap gap-4 mb-10">
        <div>
          <p class="section-label mb-3">04 · Other work</p>
          <h2 class="text-3xl md:text-5xl font-light" style="font-family: var(--font-serif); color: var(--color-accent);">
            Engineering & competitions.
          </h2>
        </div>
        <a href="/projects" class="ink-link text-sm">All projects →</a>
      </div>

      <div class="stagger grid grid-cols-1 md:grid-cols-6 gap-5">

        <!-- TITAN — wide -->
        <a href="/projects/titan" class="reveal card shimmer-border md:col-span-4 group">
          <div class="h-[3px] bg-gradient-to-r from-[#0F2A4A] via-[#1E4E7A] to-[#4A90D9]"></div>
          <div class="p-7 md:p-8">
            <div class="flex justify-between items-start mb-3">
              <span class="pill pill-amber">Paper · SeCrypt 2026</span>
              <span class="font-mono text-[11px] text-[var(--color-faint)]">Capstone</span>
            </div>
            <h3 class="text-2xl font-semibold mb-2" style="font-family: var(--font-serif); color: var(--color-accent);">TITAN</h3>
            <p class="text-[var(--color-muted)] leading-relaxed max-w-xl">
              KYC without exposing KYC. AI document forensics + ZK identity attestation + GNN-based AML transaction analysis — three layers, one structural guarantee.
            </p>
          </div>
        </a>

        <!-- ARC AGI -->
        <a href="/projects/arc-agi" class="reveal card shimmer-border md:col-span-2 group">
          <div class="h-[3px] bg-gradient-to-r from-[#B4892A] to-[#8A6414]"></div>
          <div class="p-6">
            <div class="flex justify-between items-start mb-3">
              <span class="pill pill-green">Active</span>
              <span class="font-mono text-[11px] text-[var(--color-faint)]">Kaggle</span>
            </div>
            <h3 class="text-xl font-semibold mb-2" style="font-family: var(--font-serif); color: var(--color-accent);">ARC AGI 3</h3>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">
              Abstract reasoning benchmark where brute force stops working.
            </p>
          </div>
        </a>

        <!-- WaySafe -->
        <a href="/projects/waysafe" class="reveal card shimmer-border md:col-span-2 group">
          <div class="h-[3px] bg-gradient-to-r from-[#B4892A] to-[#F5EBC9]"></div>
          <div class="p-6">
            <div class="flex justify-between items-start mb-3">
              <span class="pill pill-gold">7th · Hackverse</span>
              <span class="font-mono text-[11px] text-[var(--color-faint)]">36h</span>
            </div>
            <h3 class="text-xl font-semibold mb-2" style="font-family: var(--font-serif); color: var(--color-accent);">WaySafe</h3>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">
              Safety-weighted tourist route optimization. MIT Bangalore · Sep 2025.
            </p>
          </div>
