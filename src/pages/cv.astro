---
import Base from '../layouts/Base.astro';
---

<Base title="CV — Aryan D Haritsa">

  <!-- Page Header -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04]">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="lines-cv" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
            <line x1="0" y1="20" x2="20" y2="0" stroke="#1A365D" stroke-width="0.3"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#lines-cv)"/>
      </svg>
    </div>

    <div class="max-w-[720px] mx-auto px-6 pt-16 pb-10 relative">
      <p class="text-sm uppercase tracking-[0.12em] text-[var(--color-faint)] font-medium mb-3">Document</p>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight mb-4" style="font-family: var(--font-serif); color: var(--color-accent);">
        Curriculum Vitae
      </h1>
      <div class="flex items-center gap-4">
        <a href="/resume.pdf" download class="inline-flex items-center gap-2 px-5 py-2.5 bg-[var(--color-accent)] text-white rounded-md hover:bg-[var(--color-accent)]/90 transition-colors font-medium text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Download PDF
        </a>
        <span class="text-xs text-[var(--color-faint)]">Last updated: April 2026</span>
      </div>
    </div>
  </section>

  <div class="max-w-[720px] mx-auto px-6"><div class="h-px bg-gradient-to-r from-transparent via-[var(--color-accent)]/20 to-transparent"></div></div>

  <!-- PDF Embed -->
  <section class="max-w-[720px] mx-auto px-6 pt-10 pb-16">
    <div class="border border-[var(--color-rule)] rounded-lg overflow-hidden bg-white shadow-sm">
      <iframe
        src="/resume.pdf"
        class="w-full border-0"
        style="height: 80vh;"
        title="Aryan D Haritsa — Curriculum Vitae"
      >
        <p class="p-8 text-sm text-[var(--color-muted)]">
          Your browser does not support embedded PDFs.
          <a href="/resume.pdf" class="text-[var(--color-accent)] font-medium hover:underline">Download the PDF</a> instead.
        </p>
      </iframe>
    </div>
  </section>

</Base>
